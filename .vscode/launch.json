{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web - Chrome",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/lib/main.dart",
      "toolArgs": [
        "-d",
        "chrome"
      ],
      "flutterMode": "debug"
    },
    {
      "name": "Flutter Web - Chrome (profile)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/lib/main.dart",
      "toolArgs": [
        "-d",
        "chrome"
      ],
      "flutterMode": "profile"
    },
    {
      "name": "Flutter Web - Chrome (release)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/lib/main.dart",
      "toolArgs": [
        "-d",
        "chrome"
      ],
      "flutterMode": "release"
    }
  ]
}
